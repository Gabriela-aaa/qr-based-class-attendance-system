    {
      "name": "Phase 7 - Export PDF and Excel",
      "item": [
        {
          "name": "Export PDF (Instructor/Admin)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const roleToken = pm.collectionVariables.get('token_instructor') || pm.collectionVariables.get('token_admin');",
                  "pm.collectionVariables.set('token', roleToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/export?format=pdf&courseID={{courseID}}",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "export"],
              "query": [
                { "key": "format", "value": "pdf" },
                { "key": "courseID", "value": "{{courseID}}" }
              ]
            }
          }
        },
        {
          "name": "Export Excel (CSV) (Instructor/Admin)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const roleToken = pm.collectionVariables.get('token_instructor') || pm.collectionVariables.get('token_admin');",
                  "pm.collectionVariables.set('token', roleToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/export?format=excel&courseID={{courseID}}",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "export"],
              "query": [
                { "key": "format", "value": "excel" },
                { "key": "courseID", "value": "{{courseID}}" }
              ]
            }
          }
        },
        {
          "name": "Instructor Closes Session",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.collectionVariables.set('token', pm.collectionVariables.get('token_instructor'));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionID}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionID}}", "close"]
            }
          }
