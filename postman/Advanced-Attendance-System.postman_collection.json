    {
      "name": "Phase 3 - Courses, Sessions, QR, Eligibility",
      "item": [
        {
          "name": "Admin Adds Course",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.collectionVariables.set('token', pm.collectionVariables.get('token_admin'));"],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('courseID', String(json.course.courseID));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseCode\": \"CS301\",\n  \"courseName\": \"Web Engineering\",\n  \"department\": \"Computer Science\",\n  \"creditHour\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "List Courses (Any Auth User)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "Instructor Creates Session (QR Generated)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.collectionVariables.set('token', pm.collectionVariables.get('token_instructor'));"],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('sessionID', String(json.session.sessionID));",
                  "  pm.collectionVariables.set('qrToken', json.session.qrToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseID\": {{courseID}},\n  \"sessionDate\": \"2026-05-08\",\n  \"startTime\": \"09:00\",\n  \"gpsLocation\": \"6.5244,3.3792\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["sessions"]
            }
          }
        },
        {
          "name": "Instructor Lists My Sessions",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.collectionVariables.set('token', pm.collectionVariables.get('token_instructor'));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/my",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "my"]
            }
          }
        },
        {
          "name": "Student Checks My Eligibility",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["pm.collectionVariables.set('token', pm.collectionVariables.get('token_student'));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/eligibility/my?courseID={{courseID}}",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "eligibility", "my"],
              "query": [{ "key": "courseID", "value": "{{courseID}}" }]
            }
          }
        }
      ]
    },
