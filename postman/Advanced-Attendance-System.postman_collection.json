        {
          "name": "Register Student",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student01\",\n  \"password\": \"password123\",\n  \"studentID\": \"STU1001\",\n  \"firstName\": \"Hanna\",\n  \"lastName\": \"Smith\",\n  \"department\": \"Computer Science\",\n  \"year\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register/student",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", "student"]
            }
          }
        },
        {
          "name": "Login Admin (set token_admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token_admin', json.token);",
                  "}",
                  "pm.collectionVariables.set('token', pm.collectionVariables.get('token_admin'));"
